# Database Configuration (for production PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=nitrous

# JWT Secret Key (CHANGE THIS!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Port
PORT=8080

# Frontend Origin (for CORS)
FRONTEND_URL=http://localhost:3000

# External Data Providers
JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1
OPENF1_BASE_URL=https://api.openf1.org/v1
SPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
SPORTSDB_API_KEY=3

# Sync/Poll Intervals
JOLPICA_SYNC_INTERVAL=24h
OPENF1_ACTIVE_INTERVAL=5s
OPENF1_IDLE_INTERVAL=1h
SPORTSDB_SYNC_INTERVAL=168h

# HTTP timeout for external provider calls
EXTERNAL_REQUEST_TIMEOUT=10s
